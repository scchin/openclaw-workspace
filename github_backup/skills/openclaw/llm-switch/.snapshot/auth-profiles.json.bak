{
  "version": 1,
  "profiles": {
    "openrouter:default": {
      "type": "api_key",
      "provider": "openrouter",
      "key": "sk-or-v1-[GENERIC_SECRET_REDACTED]"
    },
    "custom-custom92:default": {
      "type": "api_key",
      "provider": "custom-custom92",
      "key": "0000"
    },
    "ollama-ollama:default": {
      "type": "api_key",
      "provider": "ollama-ollama",
      "key": "ollama-local"
    },
    "google:default": {
      "type": "api_key",
      "provider": "google",
      "key": "[GCP_API_KEY_REDACTED]"
    },
    "google-ai:default": {
      "type": "api_key",
      "provider": "google-ai",
      "key": "[GCP_API_KEY_REDACTED]"
    }
  }
}
